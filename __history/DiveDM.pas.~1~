procedure TDM.DoConfiguration(Msg: string);
var
  H, S: string;
  I: INTEGER;
  SArray: TArray<string>;
begin
  SArray := Msg.Split(['|']);

  // apply SB5CONTROL's new settings by changing 'Style'...
  H := SArray[1];
  // only do if it is for this scoreboard
  if H = LHost then
  begin
    S := SArray[2]; // DR Hostname
    DRHost := S; // set new DR Hostname
    if Length(DRHost) = 0 then
    begin
      FrmHosts.RgpHosts.ItemIndex := 0
    end
    else
    begin
      I := FrmHosts.RgpHosts.Items.IndexOf(DRHost);
      if I > 0 then
        FrmHosts.RgpHosts.ItemIndex := I
      else
      begin
        FrmHosts.RgpHosts.Items.Add(DRHost);
        I := FrmHosts.RgpHosts.Items.IndexOf(DRHost);
        FrmHosts.RgpHosts.ItemIndex := I;
      end;
    end;
    S := SArray[3]; // Style
    Style := StrToInt(S);
    // ScoreBoard style
    FrmMain.RgpStyle.ItemIndex := Style;
  end;
end;

