procedure TDM.InitialiseLanguage;
var
  ALanguage: INTEGER;
begin
  // we only come here if the Active Language has not been set.
  // comment-out invalid languages
  ALanguage := SysLocale.PriLangID;
  case ALanguage of
    // LANG_CATALAN:
    // Language := 15; // 3
    LANG_CHINESE:
      Language := 13; // 4
    LANG_DANISH:
      Language := 9; // 6
    // LANG_GERMAN:
    // Language := 4; // 7
    LANG_SPANISH:
      Language := 5; // 10
    LANG_FRENCH:
      Language := 3; // 12
    // LANG_HUNGARIAN:
    // Language := 16; // 14
    LANG_ITALIAN:
      Language := 6; // 16
    LANG_DUTCH:
      Language := 2; // 19
    LANG_NORWEGIAN:
      Language := 14; // 20
    LANG_POLISH:
      Language := 12; // 21
    LANG_RUSSIAN:
      Language := 11; // 25
    LANG_CROATIAN:
      Language := 7; // 26
    LANG_SWEDISH:
      Language := 10; // 29
    LANG_TURKISH:
      Language := 8; // 31
    LANG_UKRAINIAN:
      Language := 17; // 34
    LANG_FARSI:
      Language := 18; // 41
    LANG_CZECH:
      Language := 19; // 5
  else
    Language := 1; // English (default)
  end;
end;

procedure TDM.DataModuleCreate(Sender: TObject);
var
  RecPath: array [0 .. MAX_PATH] of CHAR;
  D, P: string;
  Sr: TSearchRec;
  T: TDateTime;
begin
  // ReportMemoryLeaksOnShutdown := True;
  AFormatSettings := TFormatSettings.Create(GetUserDefaultLCID);
  IsVista := CheckWin32Version(6);
  AppPath := ExtractFilePath(Application.Exename);
  ObtainVersionInfo(Application.Exename);

  DataPath := '';
  FillChar(RecPath, SizeOf(RecPath), 0);
  if SHGetSpecialFolderPath(0, RecPath, $0023, FALSE) then
    DataPath := RecPath + '\MDT\DRUtils\'
  else
    DataPath := '';
  if Length(DataPath) = 0 then
  begin
    MessageDlg(SiLangRTDM.GetTextOrDefault('IDS_107'
      (* 'Unable to locate Common Application Data folder.' *) ) + #13#10 + SiLangRTDM.GetTextOrDefault('IDS_108'
      (* 'This is a Critical Error.' *) ), MtError, [MbOK], 0);
    Exit;
  end;

  EDBEngine1.Active := TRUE;
  DRUSession.Open;

  // does DiveDb exist?
  ConfigurationQuery.SQL.Text := 'SELECT * FROM Databases WHERE Name=' + Engine.QuotedSQLStr('DRUDatabase');
  ConfigurationQuery.Open;
  if (ConfigurationQuery.RecordCount = 0) then
  begin
    // database does not exist .. so create it
    ConfigurationQuery.Close;
    ConfigurationQuery.SQL.Text := 'CREATE DATABASE "DRUDatabase" PATH ' + Engine.QuotedSQLStr(DataPath + 'DRUData') +
      ' DESCRIPTION ''DiveRecorder Utilities database''';
    ConfigurationQuery.ExecSQL;
  end
  else
  begin
    ConfigurationQuery.Close;
    ConfigurationQuery.SQL.Text := 'ALTER DATABASE "DRUDatabase" PATH ' + Engine.QuotedSQLStr(DataPath + 'DRUData') +
      ' DESCRIPTION ''DiveRecorder Utilities database''';
    ConfigurationQuery.ExecSQL;
  end;

  // now tidy up by deleting any tables older than 1 day
  // left behind after an improper shutdown
  D := DataPath + 'DRUData\';
  P := D + '*.*';
  if FindFirst(P, 0, Sr) = 0 then
  begin
    repeat
      T := Sr.TimeStamp;
      if ((Now - T) > 1) then
      begin
        DeleteFile(D + Sr.Name);
      end;
    until FindNext(Sr) <> 0;
    FindClose(Sr);
  end;

  DiveDb.Open;

  // now create all the temp tables
  TableCreate('NewTabScoreB.SQL');
  TableCreate('NewTabS1.SQL');
  TableCreate('NewTabS2.SQL');
  TableCreate('NewTabS3.SQL');
  TableCreate('NewTabTempResult.SQL');

  ScoreBTable.Open;
  S1Table.Open;
  S2Table.Open;
  S3Table.Open;
  TempResTable.Open;

  DRIniFile := TIniFile.Create(DataPath + 'ScoreBoard.ini');
  Shadow := FALSE;

  // Following removal of DisplayPanels form in September 2020, need to delete some .ini entries
  DRIniFile.DeleteKey('General', 'PanelType');
  DRIniFile.DeleteKey('General', 'ScrollRate');
  DRIniFile.DeleteKey('General', 'COMPort');
  DRIniFile.DeleteKey('General', 'SwapPanels');
  DRIniFile.DeleteKey('General', 'BaudRate');
  // The above can be removed once diving resumes

  Language := DRIniFile.ReadInteger('General', 'Language', 0);
  Languages := DRIniFile.ReadString('General', 'Languages', '1110111111110100111');
  HalfChar := DRIniFile.ReadString('General', 'Half', '+');
  SiLangDispatcher1.FileName := DataPath + 'ScoreBoard.sib';
  ShowSeconds := DRIniFile.ReadBool('General', 'ShowSeconds', FALSE);
  UseRankVersion := DRIniFile.ReadBool('General', 'UseRankVersion', FALSE);
  FieldHeight := DRIniFile.ReadInteger('General', 'FieldHeight', 59);
  MaxRows := DRIniFile.ReadInteger('General', 'MaxRows', 10);
  FontSize := DRIniFile.ReadInteger('General', 'FontSize', 36);
  if FileExists(SiLangDispatcher1.FileName) then
    SiLangDispatcher1.LoadAllFromFile(SiLangDispatcher1.FileName);
  while Length(Languages) < 16 do
    Languages := Languages + '0';
  while Length(Languages) < 19 do
    Languages := Languages + '1';
  if Language = 0 then
    InitialiseLanguage;
  SiLangDispatcher1.ActiveLanguage := Language;
  LoadPenalties;
  MessageList := TStringList.Create;
  MessageList.Sorted := TRUE;
  MessageList.Duplicates := DupIgnore;
  HostNameList := TStringList.Create;
  HostNameList.Sorted := TRUE; // need this
  HostNameList.Duplicates := DupIgnore; // need this
  WinTop := 50;
  WinLeft := 50;
  WinWidth := 700;
  WinHeight := 500;
  WinState := WsNormal;
  BordStyle := BsSizeable;
  SetHostAndIP;

  UDPServer.DefaultPort := UDPServerPort; // 58091
  UDPServer.Bindings.Clear;
  UDPServer.Active := TRUE;
  IdTCPClientXfer.Port := FileTransferPort; // 58291

