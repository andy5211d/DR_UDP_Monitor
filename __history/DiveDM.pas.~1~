            FrmDual.Show;
            F := 11;
          end;
      end;
    2:
      begin
        FrmResult.Show;
        F := 5;
      end;
    3:
      begin
        FrmMsgBoard.Show;
        F := 6;
      end;
    4: // Should not be needed any more (Feb 2020)
      begin
        FrmBlank.Show;
        F := 7;
      end;
    5:
      begin
        FrmCDClock.Show;
        F := 8;
      end;
    6:
      begin
        FrmStartList.Show;
        F := 12;
      end;
    7:
      begin
        FrmJudgeList.Show;
        F := 13;
      end;
    8:
      begin
        FrmTeamPoints.Show;
        F := 14;
      end;
    9:
      begin
        FrmMedals.Show;
        F := 15;
      end;
  end;
  // now close any other forms
  if F <> 1 then
    if Frmindividual.Visible then
    begin
      Frmindividual.Close;
    end;
  if F <> 2 then
    if FrmSynchro.Visible then
      FrmSynchro.Close;
  if F <> 3 then
    if FrmDetailed.Visible then
      FrmDetailed.Close;
  if F <> 4 then
    if FrmNumber.Visible then
      FrmNumber.Close;
