procedure TDM.UDPServerUDPRead(AThread: TIdUDPListenerThread; const AData: TIdBytes; ABinding: TIdSocketHandle);
var
  H, Msg, N, S: string;
  SArray: TArray<string>;
begin
  // the incoming data is UTF8 encoded ..
  // .. so read and convert the bytes to a string
  Msg := Trim(BytesToString(AData, IndyTextEncoding_UTF8));
  // check for end of message
  if Msg.EndsWith('^') then
  begin
    // but it could end with either '|^' or '^'
    if Msg.EndsWith('|^') then
      Msg := Msg.Substring(0, Msg.IndexOf('|^'))
    else
      Msg := Msg.Substring(0, Msg.IndexOf('^'));

    SArray := Msg.Split(['|']);

    if SArray[0].Equals('SBCONTROL') then
    begin
      // send settings to SBCONTROL
      S := 'SCOREBOARD' + Sep + LHost + Sep + DRHost + Sep + IntToStr(Style);
      UDPServer.Send(ABinding.PeerIP, ABinding.PeerPort, S, IndyTextEncoding_UTF8);
    end
    else
      if SArray[0].Equals('DIVERECORDER') then
      begin
        TThread.Queue(nil,
          procedure
          begin
            HostNameList.Add(SArray[1]);
          end);
      end
      else
        if ((SArray[0].Equals('CLOCK')) or (SArray[0].Equals('DRCONFIG')) or (SArray[0].Equals('UPDATE'))) then
        begin
          // it is a valid message type .. but
          // .. make sure it is relevant
          H := SArray[2]; // DR Hostname
          N := SArray[3]; // EventMode

          // only continue if host matches or does not exist or EventMode = '0'
          if ((Length(DRHost) = 0) or (DRHost = H) or (N = '0')) then
          begin
            TThread.Queue(nil,
              procedure
              begin
                MessageList.Add(Msg);
                if not UpdateTimer.Enabled then
                  UpdateTimer.Enabled := TRUE;
              end);
          end;
        end;
  end;
  // otherwise ignore the message
end;

procedure TDM.UpdateTimerTimer(Sender: TObject);
var
  Msg: string;
begin
  if not TransferringData then
  begin
    if MessageList.Count > 0 then
    begin
      Msg := MessageList.Strings[0];
      MessageList.Delete(0);
      if Msg.StartsWith('UPDATE') then
        GetUpdateFile(Msg)
      else
        if Msg.StartsWith('DRCONFIG') then
          DoConfiguration(Msg)
        else
          if Msg.StartsWith('CLOCK') then
            DoClock(Msg);
    end
    else
      UpdateTimer.Enabled := FALSE;
  end;
end;

procedure TDM.DoClock(Msg: string);
var
  E: string;
  Etime: TDateTime;
  Hour, Min, Sec: WORD;
  SArray: TArray<string>;
begin
  SArray := Msg.Split(['|']);

  Hour := StrToInt(SArray[3]); // Hour
  Min := StrToInt(SArray[4]); // Minute
  Sec := StrToInt(SArray[5]); // Seconds
  E := SArray[6]; // Event Title

  Etime := Now;
  Etime := RecodeTime(Etime, Hour, Min, Sec, 0);

  if Etime > Now then
  begin
    // set up and start the clock
    TargetTime := Etime;
    FrmCDClock.LblEvent.Caption := E;
    FrmCDClock.LblCountdown.Visible := TRUE;
    FrmCDClock.SetVisible;
    FrmCDClock.CTimer.Enabled := TRUE;
  end;
end;

procedure TDM.GetUpdateFile(Msg: string);
var
  Ms: TMemoryStream;
  LocalFileName: string;
  SArray: TArray<string>;
begin
  // This will ask a DR Host to stream an Update.txt file back
  TransferringData := TRUE; // ie we are now updating
  SArray := Msg.Split(['|']);

  // we should not be connected, but make sure so that we can change host
  if IdTCPClientXfer.Connected then
    IdTCPClientXfer.Disconnect;
  IdTCPClientXfer.Host := SArray[4]; // IP Address
  // DataPath = '\MDT\DRUtils\'
  LocalFileName := DataPath + 'Xfer\Update.txt';
  if FileExists(LocalFileName) then
    DeleteFile(LocalFileName); // delete any previous local file

  // -- New code
  Ms := TMemoryStream.Create;
  try

    try
      IdTCPClientXfer.Connect;
    except
      on E: EIdConnClosedGracefully do
      begin
        IdTCPClientXfer.Disconnect;
        if IdTCPClientXfer.IOHandler <> nil then
          IdTCPClientXfer.IOHandler.InputBuffer.Clear;
        Sleep(50);
        try
          // try again   (don't know if we actually need this)
          IdTCPClientXfer.Connect;
        except
          // give up .. we tried
        end;
      end;
    end;

    try
      IdTCPClientXfer.IOHandler.WriteLn('XFER|Update.txt');
      IdTCPClientXfer.IOHandler.ReadStream(Ms, -1, FALSE);
      Ms.SaveToFile(LocalFileName);
    finally
      IdTCPClientXfer.Disconnect;
    end;
    DoUpdate; // DoUpdate checks for existence of file

  finally
    Ms.Free;
    TransferringData := FALSE;
  end;
end;

procedure TDM.DoUpdate;
var
  Eventmode, H, Msg, N, T: string;
  IsCircuit: BOOLEAN;
  StrList: TStringList;
  SArray: TArray<string>;
  Cs, I, P, R, So, StartNumber, Recs: INTEGER;
  Board, Sc: CURRENCY;
begin
  // This new version reads and processes the downloaded file
  // BUT only do all this if a file exists
  if FileExists(DataPath + 'Xfer\Update.txt') then
  begin

    StrList := TStringList.Create;;
    StrList.LoadFromFile(DataPath + 'Xfer\Update.txt');
    Msg := StrList[0];
    StrList.Free;

    // Msg does have a terminating '|^'
    Msg := Msg.Substring(0, Msg.IndexOf('|^'));

    // if Farsi Language we must replace the ½ characters
    if Language = 18 then
    begin
      Msg := Msg.Replace('½', FormatSettings.DecimalSeparator + '5', [RfReplaceAll])
    end;

    SArray := Msg.Split(['|']);

    Eventab := SArray[1]; // Event a or b
    H := SArray[2]; // DR Hostname
    Eventmode := SArray[3]; // EventMode

    // now do the ScoreBTable data
    if (ScoreBTable.RecordCount = 0) then
      ScoreBTable.Insert
    else
      ScoreBTable.Edit;

    for I := 0 to ScoreBTable.FieldCount - 1 do
    begin
      try
        ScoreBTable.Fields[I].AsString := SArray[I + 4];
      except
        // could this be a decimalseparator mismatch?
        T := SArray[I + 4];
        T := T.Replace('.', FormatSettings.DecimalSeparator);
        // try again
        ScoreBTable.Fields[I].AsString := T;
      end;
    end;

    if ScoreBTable['DoNotRank'] then
      // make sure not using Ranking versions of scoreboard
      FrmMain.CbRanks.Checked := FALSE;

    ScoreBTable.Post;
    ScoreBTable.Refresh;

    // May 2019:  Now do cludge edit of height for High Diving
    if HighDiving then
    begin
      Board := ScoreBTable['Board'];
      if Board > 5 then
      begin
        ScoreBTable.Edit;
        if Board = 7.5 then
          Board := 20
        else
          if Board = 10 then
            Board := 27;
        ScoreBTable['Board'] := Board;
        ScoreBTable.Post;
      end;
    end;

    if ScoreBTable.FieldByName('SBMode').AsString = '' then
      ScoreBoardMode := 2
    else
    begin
      ScoreBoardMode := ScoreBTable['SBMode'];
    end;

    Synchro := ScoreBTable.FieldByName('Synch').AsBoolean;
    TeamEvent := ScoreBTable.FieldByName('TeamEvent').AsInteger;

    // strip 'P' from Place
    T := ScoreBTable.FieldByName('Place').AsString;
    if T.StartsWith('P') then
    begin
      T := T.Remove(0, 1);
      ScoreBTable.Edit;
      ScoreBTable['Place'] := T;
      ScoreBTable.Post;
    end
    else if T.StartsWith('S') then
    begin
      T := T.Remove(0, 1);
      ScoreBTable.Edit;
      ScoreBTable['Place'] := T;
      ScoreBTable.Post;
    end;

    // trim both Needs and Prediction
    T := Trim(ScoreBTable.FieldByName('Needs').AsString);
    ScoreBTable.Edit;
    ScoreBTable.FieldByName('Needs').AsString := T;
    T := Trim(ScoreBTable.FieldByName('Predict').AsString);
    ScoreBTable.FieldByName('Predict').AsString := T;
    ScoreBTable.Post;
    if not(ScoreBTable.FieldByName('Jdgs').AsString = '') then
      NumberOfJudges := ScoreBTable['Jdgs'];
    if ((not(ScoreBTable.FieldByName('Stations').AsString = '')) and (ScoreBTable.FieldByName('Stations').AsInteger > 0))
    then
      NoOfStations := ScoreBTable['Stations'];

    IsCircuit := ScoreBTable.FieldByName('Station').AsInteger > -1;

    // we need to check for a possible change of Style
    if ScoreBoardMode = 1 then
      if Style < 2 then
        case Style of
          0:
            if IsCircuit then
            begin
              Style := 1;
              FrmMain.RgpStyle.ItemIndex := Style;
            end;
          1:
            if not IsCircuit then
            begin
              Style := 0;
              FrmMain.RgpStyle.ItemIndex := Style;
            end;
        end;

    // now check for circuits or event a/b and copy data
    if (IsCircuit and not(ScoreBTable.FieldByName('Station').AsString = '')) then
      Cs := ScoreBTable['Station']
    else
    begin
      // but if A/B we may need to switch style, etc
      // .. first set normal event number
      if Eventab = 'a' then
        Cs := 0
      else
        Cs := 1;
      // .. now do the trickier bits
      if ((DRHost = H) or (Eventmode = '0') or Synchro) then
      begin
        // we can assume we have only one event, so ..
        Cs := 0;
        // only think of changing if style is circuit or dual
        if ((Style = 1) or (Style = 4)) then
        begin
          Style := 0;
          FrmMain.RgpStyle.ItemIndex := Style;
        end;
      end
      else // this looks like dual events, so ..
        if ((Eventab = 'b') and (DRHost = '')) then
          if not(Style = 4) then
          begin
            Style := 4;
            FrmMain.RgpStyle.ItemIndex := Style;
          end;
    end;

    // if it is a new event we need to wipe the tables..
    // ..it is a 'new event' if it says it is a new event!
    if (ScoreBTable.FieldByName('NewEvent').AsBoolean = TRUE) then
    begin
      NewEvent := TRUE;
      // OK, it is new so wipe any old data
      if CopyScript.Active then
        CopyScript.Close;
      CopyScript.SQL.Clear;
      CopyScript.SQL.Add('SCRIPT ()');
      CopyScript.SQL.Add('BEGIN');
      if ScoreBTable.FieldByName('SBMode').AsInteger = 2 then
      begin
        CopyScript.SQL.Add('EXECUTE IMMEDIATE ''DELETE FROM "S1"'';');
        CopyScript.SQL.Add('EXECUTE IMMEDIATE ''DELETE FROM "S2"'';');
        CopyScript.SQL.Add('EXECUTE IMMEDIATE ''DELETE FROM "S3"'';');
      end
      else
        case Cs of
          0:
            CopyScript.SQL.Add('EXECUTE IMMEDIATE ''DELETE FROM "S1"'';');
          1:
            CopyScript.SQL.Add('EXECUTE IMMEDIATE ''DELETE FROM "S2"'';');
          3:
            CopyScript.SQL.Add('EXECUTE IMMEDIATE ''DELETE FROM "S3"'';');
        end;
      CopyScript.SQL.Add('END');
      // CopyScript.SQL.SaveToFile(DataPath + 'debug.sql');   // only for debugging
      CopyScript.ExecScript;
    end
    else
    begin
      NewEvent := FALSE;
    end;

    // now do the copy
    if CopyScript.Active then
      CopyScript.Close;
    CopyScript.SQL.Clear;
    CopyScript.SQL.Add('SCRIPT ()');
    CopyScript.SQL.Add('BEGIN');
    case Cs of
      0:
        begin
          CopyScript.SQL.Add('EXECUTE IMMEDIATE ''DELETE FROM "S1"'';');
          CopyScript.SQL.Add('EXECUTE IMMEDIATE ''INSERT INTO "S1"');
          CopyScript.SQL.Add('SELECT * FROM "ScoreB"'';');
        end;
      1:
        begin
          CopyScript.SQL.Add('EXECUTE IMMEDIATE ''DELETE FROM "S2"'';');
          CopyScript.SQL.Add('EXECUTE IMMEDIATE ''INSERT INTO "S2"');
          CopyScript.SQL.Add('SELECT * FROM "ScoreB"'';');
        end;
      3:
        begin
          CopyScript.SQL.Add('EXECUTE IMMEDIATE ''DELETE FROM "S3"'';');
          CopyScript.SQL.Add('EXECUTE IMMEDIATE ''INSERT INTO "S3"');
          CopyScript.SQL.Add('SELECT * FROM "ScoreB"'';');
        end;
    end;
    CopyScript.SQL.Add('END');
    CopyScript.SQL.SaveToFile(DataPath + 'debug1.sql');
    CopyScript.ExecScript;
    S1Table.Refresh;
    S2Table.Refresh;
    S3Table.Refresh;

    // now do TempResTable data
    // but skip if a circuit event during Recording
    if not(IsCircuit and (ScoreBoardMode = 1)) then
    begin
      {
        The value in 'Round' is used to indicate the records to be displayed
        0..99 means move cursor to that record number
        100 - means go to the first record (show first page)
        101 - means go up one page
        102 - means go down one page
        103 - means show last full page
      }
      R := 0;
      StartNumber := ScoreBTable.FieldByName('EStart').AsInteger;
      TempResTable.DisableControls;
      try
        TempResTable.Last;
        while not TempResTable.Bof do
          TempResTable.Delete;

        // Initialise array index
        // If this index results in errors ..
        // .. you need to check the FieldCounts for the 4 ScoreB table components!
        I := DM.ScoreBTable.FieldCount + 4;

        while I < Length(SArray) do
        begin
          N := SArray[I]; // Place
          if Length(N) > 0 then
          begin
            P := StrToInt(N)
          end
          else
          begin
            P := 1000; // Not Placed!
          end;
          Inc(I);

          N := SArray[I]; // Score
          if Length(N) > 0 then
          begin
            N := N.Replace('.', FormatSettings.DecimalSeparator);
            Sc := StrToCurr(Trim(N));
          end
          else
          begin
            Sc := NoScore;
          end;

          Inc(I);
          R := StrToInt(SArray[I]); // Round

          Inc(I);
          N := SArray[I]; // Name

          Inc(I);
          So := StrToInt(SArray[I]); // StartOrder

          Inc(I);
          T := SArray[I]; // TeamCode

          Inc(I);

          if P = 1000 then
          begin
            DM.TempResTable.InsertRecord([nil, Sc, So, R, N, T])
          end
          else
            if Sc = NoScore then
            begin
              DM.TempResTable.InsertRecord([P, nil, So, R, N, T])
            end
            else
            begin
              DM.TempResTable.InsertRecord([P, Sc, So, R, N, T]);
            end;
        end;
        Recs := TempResTable.RecordCount;

        // special case for 'normal' display - show only top scores if
        // UseRankVersion is set for Individual or Synchro display
        if ((ScoreBoardMode = 1) and (Style = 0) and (UseRankVersion)) then
          R := 100;

        // next section tries to display the correct record or page
        case R of
          0 .. 99: // move cursor to record 'r'
            TempResTable.Locate('StartOrder', StartNumber, []);
          100: // first page
            begin
              TempResTable.First;
              GoUpTo := 1;
              GoDownTo := ScrollRows; // number of rows in grid
              if GoDownTo > Recs then
                GoDownTo := Recs;
              GoingDown := FALSE; // set direction as if we were going up to top
            end;
          101: // previous page
            begin
              // The trick here is to determine the correct value for GoUpTo
              if GoingDown then
                // changing direction, so ..
                // .. recalculate GoUpTo by reference to GoDownTo
                GoUpTo := GoDownTo - 8 - (ScrollRows - 1)
              else
                Dec(GoUpTo, ScrollRows); // already going up so scroll by ScrollRows
              if GoUpTo < 1 then
                GoUpTo := 1;
              TempResTable.Last;
              for P := Recs downto GoUpTo + 1 do
                TempResTable.Prior;
              GoDownTo := GoUpTo + (ScrollRows - 1);
              if GoDownTo > Recs then
                GoDownTo := Recs;
              GoingDown := FALSE; // remember direction
            end;
          102: // next page
            begin
              // The trick here is to determine the correct value for GoDownTo
              if GoingDown then
                Inc(GoDownTo, ScrollRows) // already going down so only move by Scrollrows
              else
              begin
                // Change of direction - was going up, so ..
                // .. recalculate GoDownTo by reference to GoUpTo
                GoDownTo := GoUpTo + 8 + (ScrollRows - 1);
              end;
              if GoDownTo > Recs then
                GoDownTo := Recs;
              TempResTable.First;
              for P := 1 to GoDownTo - 1 do
                TempResTable.Next;
              GoUpTo := GoDownTo - (ScrollRows - 1);
              if GoUpTo < 1 then
                GoUpTo := 1;
              GoingDown := TRUE; // remember direction
            end;
          103: // last page
            begin
              TempResTable.Last;
              GoDownTo := Recs;
              GoUpTo := Recs - ScrollRows;
              if GoUpTo < 1 then
                GoUpTo := 1;
              GoingDown := TRUE; // set direction as if we were going down to bottom
            end;
        end;
      finally
        TempResTable.EnableControls;
      end;

    end;

    if not ScoreBTable.FieldByName('BackGrnd').IsNull then
      ClBack := ScoreBTable['BackGrnd'];
    if not ScoreBTable.FieldByName('AText').IsNull then
      ClTextA := ScoreBTable['AText'];
    if not ScoreBTable.FieldByName('BText').IsNull then
      ClTextB := ScoreBTable['BText'];
    if not ScoreBTable.FieldByName('Labels').IsNull then
      ClLabels := ScoreBTable['Labels'];

    SetPanel(ScoreBoardMode);
    DoVisible;
  end;
end;

