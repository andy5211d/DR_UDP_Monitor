procedure TForm2.DecodeClick(Sender: TObject);
var
  i : Integer;
  data  : string;
  text: string;
  Column: TListColumn;
  ListItem: TListItem;
  ListView: TListView;
begin
    case Form7.btnPressed of
    1 : begin
          setLength(headerArray, length(refereeArray));
          for i := 0 to length(refereeArray)-1 Do
          headerArray[i] := refereeArray[i];
          Label1.Caption := ('Port58091 - Referee message selected');
          array2display := Form7.refereeArray1;
        end;
    2 : begin
          setLength(headerArray, length(avideoArray));
          for i := 0 to length(avideoArray)-1 Do
          headerArray[i] := avideoArray[i];
          Label1.Caption := ('Port58091 - AVideo message selected');
          array2display := Form7.avideoArray1;
        end;
    3 : begin
          setLength(headerArray, length(updateArray));
          for i := 0 to length(updateArray)-1 Do
          headerArray[i] := updateArray[i];
          Label1.Caption := ('Port58091 - Update message selected');
          array2display := Form7.updateArray1;
        end;
    5 : begin
          setLength(headerArray, length(sbcontrolArray));
          for i := 0 to length(sbcontrolArray)-1 Do
          headerArray[i] := sbcontrolArray[i];
          Label1.Caption := ('Port58091 - SBControl message selected');
          array2display := Form7.sbcontrolArray1;
        end;
    4 : begin
          setLength(headerArray, length(drconfigArray));
          for i := 0 to length(drconfigArray)-1 Do
          headerArray[i] := drconfigArray[i];
          Label1.Caption := ('Port58091 - DRConfig message selected');
          array2display := Form7.drconfigArray1;
        end;
    6 : begin
          setLength(headerArray, length(awardArray));
          for i := 0 to length(awardArray)-1 Do
          headerArray[i] := awardArray[i];
          Label1.Caption := ('Port58091 - Award message selected');
          array2display := Form7.awardArray1;
        end;
    7 : begin
          setLength(headerArray, length(scoreboardArray));
          for i := 0 to length(scoreboardArray)-1 Do
          headerArray[i] := scoreboardArray[i];
          Label1.Caption := ('Port58092 - Scoreboard message selected');
          array2display := Form7.splitString2;
        end;
    8 : begin
          setLength(headerArray, length(helloArray));
          for i := 0 to length(helloArray)-1 Do
          headerArray[i] := helloArray[i];
          Label1.Caption := ('Port58092 - Hello message selected');
          array2display := Form7.splitString2;
        end;
    9 : begin
          setLength(headerArray, length(foundserverArray));
          for i := 0 to length(foundserverArray)-1 Do
          headerArray[i] := foundserverArray[i];
          Label1.Caption := ('Port58092 - FoundServer message selected');
          array2display := Form7.splitString2;
        end;
    10 : begin
          setLength(headerArray, length(dbserverArray));
          for i := 0 to length(dbserverArray)-1 Do
          headerArray[i] := dbserverArray[i];
          Label1.Caption := ('Port58092 - DBServer message selected');
          array2display := Form7.splitString2;
        end;
    11 : begin
          setLength(headerArray, length(diverecorderArray));
          for i := 0 to length(webupdateArray)-1 Do
          headerArray[i] := diverecorderArray[i];
          Label1.Caption := ('Port58093 - Diverecoder message selected');
          array2display := Form7.splitString3;
        end;
    12 : begin
          setLength(headerArray, length(webupdateArray));
          for i := 0 to length(webupdateArray)-1 Do
          headerArray[i] := webupdateArray[i];
          Label1.Caption := ('Port58093 - WebUpdate message selected');
          array2display := Form7.splitString3;
        end;
    13 : begin
          setLength(headerArray, length(webmessageArray));
          for i := 0 to length(webmessageArray)-1 Do
          headerArray[i] := webmessageArray[i];
          Label1.Caption := ('Port58093 - WebMessage message selected');
          array2display := Form7.splitString3;
        end;
    14 : begin
          setLength(headerArray, length(startresultArray));
          for i := 0 to length(startresultArray)-1 Do
          headerArray[i] := startresultArray[i];
          Label1.Caption := ('Port58093 - StartResult message selected');
          array2display := Form7.splitString3;
        end;
    15 : begin
          setLength(headerArray, length(awardArray));
          for i := 0 to length(awardArray)-1 Do
          headerArray[i] := awardArray[i];
          Label1.Caption := ('Port58094 - Award message selected');
          array2display := Form7.splitString4;
        end
    end;

    if Form7.btnPressed <> btnPressedOld then c := 0;    // new message type to decode so clear display
    ListView1.Items.Clear;
    if c = 0  then                                       // now get the new message and place in the next free column, 'udpArrayN'
        begin
          udpArray1 := array2display;
        end
    else if c = 1 then
        begin
          udpArray2 := array2display;
        end
    else if c = 2 then
        begin
          udpArray3 := array2display;
        end
    else if c = 3 then
        begin
          udpArray4 := array2display;
        end;

    for i  := 0 to length(array2display)-1 do
    begin
      ListItem := ListView1.Items.Add;
      ListItem.Caption := headerArray[i];
      if c = 0  then                                     //  Add the new colum of decoded data to 'listView'.   The only way that actually works but there must be a better way!!!
          begin
            ListItem.SubItems.Add(udpArray1[i]);
          end
        else if c = 1  then
          begin
            ListItem.SubItems.Add(udpArray1[i]);
            ListItem.SubItems.Add(udpArray2[i]);
          end
        else if c = 2 then
          begin
            ListItem.SubItems.Add(udpArray1[i]);
            ListItem.SubItems.Add(udpArray2[i]);
            ListItem.SubItems.Add(udpArray3[i]);
          end
        else if c = 3 then
          begin
            ListItem.SubItems.Add(udpArray1[i]);
            ListItem.SubItems.Add(udpArray2[i]);
            ListItem.SubItems.Add(udpArray3[i]);
            ListItem.SubItems.Add(udpArray4[i]);
          end;
    end;
    btnPressedOld  := Form7.btnPressed;
    Inc(c);
    if c > 3 then c := 0;

 end;


end.
