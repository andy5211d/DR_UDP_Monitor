    Label2.Caption := 'Attached to 4 UDP ports!';
    Button1.Caption := 'Disconnect';
  end

end;

// Port 85091 receive
procedure TForm7.IdUDPServer1UDPRead(AThread: TIdUDPListenerThread;
  const AData: TIdBytes; ABinding: TIdSocketHandle);

begin
  Gauge1.BackColor := clBtnFace;
  s1:= BytesToString(Adata, IndyTextEncoding_UTF8);
  Inc(tot091);
  if s1 = s1Old then
  begin
    Inc(c1);
  end
  else begin
    Inc(c1);
    s1Old := s1;
    splitString1 := mySplit(s1);
    Memo1.Lines.Add('From ' + ABinding.peerIP + ' Port: ' + IntToStr(ABinding.PeerPort) + sLinebreak + s1 + sLinebreak);
    if splitString1[0] = 'REFEREE' then
    begin
      refereeArray1 := splitString1;
      Inc(r1);;
      edit1.text := inttostr(r1);
      if btnPressed = 1 then if Form2.CheckBox1.checked then Form2.Decode.Click;
    end
    else if splitString1[0] = 'AVIDEO' then
    begin
      avideoArray1 := splitString1;
      Inc(a1);
      edit2.text := inttostr(a1);
      if btnPressed = 2 then if Form2.CheckBox1.checked then Form2.Decode.Click;
    end
    else if splitString1[0] = 'UPDATE' then
    begin
      updateArray1 := splitString1;
      Inc(u1);
      edit3.text := inttostr(u1);
      if btnPressed = 3 then if Form2.CheckBox1.checked then Form2.Decode.Click;
    end
    else if splitString1[0] = 'DRCONFIG' then
    begin
      drconfigArray1 := splitString1;
      Inc(d1);
      edit4.text := inttostr(d1);
      if btnPressed = 4 then if Form2.CheckBox1.checked then Form2.Decode.Click;
    end
    else if splitString1[0] = 'SBCONTROL' then
    begin
      sbcontrolArray1 := splitString1;
      Inc(sb1);
      edit5.text := inttostr(sb1);
      if btnPressed = 5 then if Form2.CheckBox1.checked then Form2.Decode.Click;
    end
    else if splitString1[0] = 'AWARD' then
    begin
      awardArray1 := splitString1;
      Inc(aw1);
      edit6.text := inttostr(aw1);
      if btnPressed = 6 then if Form2.CheckBox1.checked then Form2.Decode.Click;
    end
    else
    edit16.text := ('Port85091 - Unknown message type from: ' + ABinding.PeerIP + ', port: ' + IntToStr(ABinding.PeerPort));
  end;
  Gauge1.Progress := c1;
  label7.Caption := inttostr(tot091);
  if c1 < 2 then begin
    Gauge1.ForeColor := clRed;
  end
  else if c1 < 10 then
  begin
    Gauge1.ForeColor := clYellow;
  end
  else begin
    Gauge1.ForeColor := clGreen;
  end;

  if c1 >= 10 then c1 := c1 - 10;

end;


