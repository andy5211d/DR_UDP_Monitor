unit Hosts;

interface

uses
  System.Classes,
  Vcl.Graphics,
  Vcl.Controls,
  Vcl.Forms,
  Vcl.Dialogs,
  Vcl.StdCtrls,
  TB2Item,
  TB2Dock,
  TB2Toolbar,
  Vcl.CheckLst,
  Vcl.ExtCtrls,
  SiComp,
  SiLangRT,
  SpTBXItem,
  IdStack,
  // Winapi.WinSock2,
  IdBaseComponent,
  IdComponent,
  IdUDPBase,
  IdUDPClient,
  IdGlobal,
  System.ImageList,
  Vcl.ImgList,
  Vcl.VirtualImageList;

type
  TfrmHosts = class(TForm)
    Lbl1: TLabel;
    Lbl2: TLabel;
    Lbl3: TLabel;
    Lbl4: TLabel;
    RgpHosts: TRadioGroup;
    SiLangRTHosts: TsiLangRT;
    TBXDock1: TSpTBXDock;
    TBXToolbar1: TSpTBXToolbar;
    TBXItemClose: TSpTBXItem;
    TBXItemScan: TSpTBXItem;
    UDPClient: TIdUDPClient;
    ScanTimer: TTimer;
    VirtualImageListHosts: TVirtualImageList;
    procedure TBXItemCloseClick(Sender: TObject);
    procedure TBXItemScanClick(Sender: TObject);
    procedure FormCreate(Sender: TObject);
    procedure FormShow(Sender: TObject);
    procedure RgpHostsClick(Sender: TObject);
    procedure ScanTimerTimer(Sender: TObject);
    procedure SiLangRTHostsLanguageChanging(Sender: TObject; const NewLanguage: Integer; var AllowChange: Boolean);
  private
    { Private declarations }
    procedure MakeRTL; // these can go in the PRIVATE section
    procedure MakeLTR;
  public
    { Public declarations }
  end;

var
  FrmHosts: TfrmHosts;

implementation

{$r *.dfm}

uses
  System.SysUtils,
  DiveDM,
  Display,
  System.StrUtils;

var
  IsFlipped: Boolean;

procedure TfrmHosts.FormCreate(Sender: TObject);
begin
  if Application.BiDiMode = BdRightToLeft then
  begin
    // This is startup so we need to flip before changing to RTL ..
    // .. or AutoSize captions will have their alignment switched and
    // .. their left values may change
    FlipChildren(True); // or possibly False if some child components' children are not to be flipped
    IsFlipped := True;
    // if some labels do not switch initial alignment or need custom alignment, they can be done here
  end;
  // finally, we can change the form to follow the Application.BiDiMode
  ParentBiDiMode := True;

  // BroadcastIP := IP.Substring(0, IP.LastDelimiter('.'));
  // BroadcastIP := BroadcastIP + '.255'; // subnet bcast
end;

procedure TfrmHosts.FormShow(Sender: TObject);
var
  I: Integer;
begin
  SiLangRTHosts.OnLanguageChanging := SiLangRTHostsLanguageChanging;

  RgpHosts.Enabled := FALSE; // disable to stop OnClick
  if DRHost = '' then
    RgpHosts.ItemIndex := 0
  else
  begin
    I := RgpHosts.Items.IndexOf(DRHost);
    RgpHosts.ItemIndex := I;
  end;
  RgpHosts.Enabled := True; // enable to restore OnClick
end;

procedure TfrmHosts.RgpHostsClick(Sender: TObject);
var
  I: Integer;
begin
  I := RgpHosts.ItemIndex;
  if I < 1 then
    DRHost := ''
  else
    DRHost := RgpHosts.Items[I];
end;

procedure TfrmHosts.ScanTimerTimer(Sender: TObject);
var
  S: string;
begin
  for S in HostNameList do
    RgpHosts.Items.Add(S);
  ScanTimer.Enabled := FALSE;
  if DRHost <> '' then
    RgpHosts.ItemIndex := RgpHosts.Items.IndexOf(DRHost);
  if RgpHosts.ItemIndex < 1 then
    RgpHosts.ItemIndex := 0; // default = All
  Screen.Cursor := CrDefault;
end;

procedure TfrmHosts.SiLangRTHostsLanguageChanging(Sender: TObject; const NewLanguage: Integer;
  var AllowChange: Boolean);
begin
  // default is AllowChange := True;
  if NewLanguage = 18 then
    MakeRTL
  else
    MakeLTR;
end;

procedure TfrmHosts.MakeRTL;
begin
  // change to RTL, if necessary
  if not IsFlipped then
  begin
    // basic
    FlipChildren(True);
    IsFlipped := True;
    // add here any custom (alignments) for Form, if required
  end;
end;

procedure TfrmHosts.MakeLTR;
begin
  // change to LTR, if necessary
  if IsFlipped then
  begin
    // basic
    FlipChildren(True);
    IsFlipped := FALSE;
    // add here any custom (alignments) for Form, if required
  end;
end;

procedure TfrmHosts.TBXItemScanClick(Sender: TObject);
var
  I: Integer;
begin
  RgpHosts.Items.Clear;
  RgpHosts.Items.Add(SiLangRTHosts.GetTextOrDefault('IDS_7' (* 'All' *) ));
  Repaint;
  HostNameList.Clear;
  Screen.Cursor := CrHourGlass;
  ScanTimer.Enabled := True; // reads host list after 2 seconds
  // now scan for any remote utilities
  for I := 1 to 3 do
  begin
    UDPClient.Broadcast('HELLO', UDPClientPort, BroadcastIP, IndyTextEncoding_UTF8);
    Sleep(50);
  end;
end;

procedure TfrmHosts.TBXItemCloseClick(Sender: TObject);
begin
  Close;
end;

end.
